{
  "input": {
    "path": "../data/sample_contacts.csv",
    "format": "csv"
  },
  "output": {
    "path": "../output/cleaned.csv",
    "format": "csv"
  },
  "report": {
    "path": "../output/cleaning_report.json"
  },
  "modules": [
    "text.trim_whitespace",
    {
      "id": "text.normalize_for_matching",
      "options": {
        "columns": ["name"],
        "remove_punctuation": true,
        "collapse_whitespace": true
      }
    },
    {
      "id": "validation.standardize_phone",
      "options": {
        "columns": ["phone"],
        "output": "us",
        "keep_country_code": true
      }
    },
    {
      "id": "validation.standardize_zip",
      "options": {
        "columns": ["zip"],
        "output": "zip5"
      }
    },
    {
      "id": "validation.standardize_state",
      "options": {
        "columns": ["state"],
        "output": "abbr"
      }
    }
  ]
}
