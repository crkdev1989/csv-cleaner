{
  "input": "messy_contacts_500.csv",
  "pipeline": [
    {
      "module": "core.drop_empty"
    },
    {
      "module": "core.drop_empty_columns"
    },
    {
      "module": "core.drop_columns",
      "columns": [
        "junk_notes"
      ]
    },
    {
      "module": "core.rename_columns",
      "mapping": {
        "full_name": "name",
        "email_address": "email",
        "phone_number": "phone",
        "state_name": "state",
        "zip_code": "zip",
        "customer_city": "city",
        "company_name": "company",
        "signup_date": "joined_at",
        "purchase_amount": "amount",
        "age_years": "age"
      }
    },
    {
      "module": "text.trim_whitespace"
    },
    {
      "module": "text.remove_non_printable"
    },
    {
      "module": "text.normalize_empty_strings",
      "values": [
        "",
        " ",
        "n/a",
        "N/A",
        "none",
        "None",
        "unknown",
        "Unknown"
      ]
    },
    {
      "module": "text.normalize_case",
      "columns": [
        "name",
        "city",
        "company"
      ],
      "case": "title"
    },
    {
      "module": "text.normalize_case",
      "columns": [
        "email",
        "status",
        "subscribed"
      ],
      "case": "lower"
    },
    {
      "module": "text.replace_values",
      "column": "subscribed",
      "mapping": {
        "y": "yes",
        "yes": "yes",
        "true": "yes",
        "1": "yes",
        "n": "no",
        "no": "no",
        "false": "no",
        "0": "no"
      }
    },
    {
      "module": "text.replace_values",
      "column": "status",
      "mapping": {
        "active": "active",
        "inactive": "inactive",
        "pending": "pending",
        "unknown": "unknown"
      }
    },
    {
      "module": "text.normalize_for_matching",
      "columns": [
        "name",
        "email",
        "company"
      ]
    },
    {
      "module": "validation.coerce_numeric",
      "columns": [
        "amount",
        "age"
      ]
    },
    {
      "module": "validation.coerce_datetime",
      "columns": [
        "joined_at"
      ]
    },
    {
      "module": "validation.standardize_phone",
      "columns": [
        "phone"
      ]
    },
    {
      "module": "validation.standardize_zip",
      "columns": [
        "zip"
      ]
    },
    {
      "module": "validation.standardize_state",
      "columns": [
        "state"
      ]
    },
    {
      "module": "core.fill_nulls",
      "values": {
        "status": "unknown",
        "company": "Unknown",
        "subscribed": "unknown"
      }
    },
    {
      "module": "core.drop_rows_missing_required",
      "required": [
        "name",
        "email"
      ]
    },
    {
      "module": "dedupe.drop_duplicates",
      "subset": [
        "name",
        "email"
      ]
    },
    {
      "module": "core.select_columns",
      "columns": [
        "row_id",
        "name",
        "email",
        "phone",
        "state",
        "zip",
        "city",
        "company",
        "joined_at",
        "amount",
        "age",
        "status",
        "subscribed",
        "mostly_empty"
      ]
    }
  ]
}