{
  "input": {
    "path": "../data/messy_contacts_500.csv",
    "format": "csv"
  },
  "output": {
    "path": "../output/cleaned.csv",
    "format": "csv"
  },
  "report": {
    "path": "../output/cleaning_report.json"
  },
  "modules": [
    "text.trim_whitespace",
    {
      "id": "text.remove_non_printable",
      "options": {
        "collapse_whitespace": false,
        "strip": true
      }
    },
    {
      "id": "text.normalize_empty_strings",
      "options": {
        "empty_values": ["N/A", "n/a", "none", "unknown", "Unknown", "?", "temp", "delete me", "old import"]
      }
    },
    {
      "id": "text.normalize_case",
      "options": {
        "case": "lower",
        "columns": ["full_name", "customer_city", "company_name", "status"]
      }
    },
    {
      "id": "validation.standardize_phone",
      "options": {
        "columns": ["phone_number"],
        "output": "us",
        "keep_country_code": true
      }
    },
    {
      "id": "validation.standardize_zip",
      "options": {
        "columns": ["zip_code"],
        "output": "zip5"
      }
    },
    {
      "id": "validation.standardize_state",
      "options": {
        "columns": ["state_name"],
        "output": "abbr"
      }
    },
    {
      "id": "validation.coerce_numeric",
      "options": {
        "columns": ["purchase_amount", "age_years"],
        "errors": "coerce",
        "strip_commas": true,
        "strip_currency": true
      }
    },
    {
      "id": "validation.coerce_datetime",
      "options": {
        "columns": ["signup_date"],
        "errors": "coerce",
        "dayfirst": false
      }
    },
    {
      "id": "core.drop_empty_columns",
      "options": {
        "treat_blank_strings_as_empty": true
      }
    },
    "core.drop_empty",
    {
      "id": "dedupe.drop_duplicates",
      "options": { "keep": "first" }
    }
  ]
}
