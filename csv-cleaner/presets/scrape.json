{
  "pipeline": [
    {"id": "text.trim_whitespace"},
    {"id": "text.remove_non_printable", "options": {"strip": true, "collapse_whitespace": true}},
    {"id": "text.normalize_empty_strings", "options": {"empty_values": ["n/a", "N/A", ""]}},
    {"id": "text.normalize_case", "options": {"case": "lower"}},
    {"id": "core.drop_empty"},
    {"id": "dedupe.drop_duplicates", "options": {"keep": "first"}}
  ]
}
